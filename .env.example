# PostgreSQL
POSTGRES_DB=voltana
POSTGRES_USER=voltana_user
POSTGRES_PASSWORD=change_me_strong_password

# JWT — access token in memory, refresh in httpOnly cookie (ADR-003)
JWT_SECRET=change_me_min_32_chars_secret_key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# App
# Set APP_ENV=production on the VPS so the refresh cookie gets the Secure flag (ADR-003 / N1).
APP_ENV=development
PORT=9090

# Domain (production only) — used by deploy.sh to generate the nginx config.
# DOMAIN=yourdomain.example.com

# SMTP — required for email verification.
#  - Leave SMTP_HOST empty to use the dev log mailer (no email sent; link never printed).
#  - Local dev: set SMTP_HOST=mailhog and SMTP_PORT=1025 to catch verification emails in the
#    MailHog web UI at http://localhost:8025 (the `mailhog` service in docker-compose.yml).
#  - Production: point SMTP_* at a real relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@voltana.app

# Public base URL used to build the verification link (<APP_URL>/verify-email?token=...)
# Development:  APP_URL=http://localhost
# Production:   APP_URL=https://yourdomain.example.com
APP_URL=http://localhost

# Bale Bot (preferred, Iranian) — obtain from BotFather on Bale.
# Leave empty to fall back to LogOTPSender (code logged server-side; QA-only).
# BALE_BOT_TOKEN=
# BALE_BOT_USERNAME=your_bale_bot

# Telegram Bot (fallback; may be filtered on Iranian VPS — Bale is the prod primary).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=your_telegram_bot

# ── Production SMTP (replace mailhog with a real relay on VPS) ────────────────
# Resend (recommended): SMTP_HOST=smtp.resend.com SMTP_PORT=587 SMTP_USER=resend SMTP_PASSWORD=<api-key>
# Mailgun:              SMTP_HOST=smtp.mailgun.org SMTP_PORT=587 SMTP_USER=<user>@mg.domain SMTP_PASSWORD=<key>
# Note: set APP_ENV=production or the refresh cookie will not be Secure.

# ── Certbot auto-renewal cron (add once on VPS after first cert issuance) ─────
# 0 3 * * * certbot renew --quiet --deploy-hook "docker compose -f /opt/voltana/docker-compose.yml -f /opt/voltana/docker-compose.prod.yml exec nginx nginx -s reload"

# Web Push (TASK-0039) — generate a VAPID pair (e.g. npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=changeme-vapid-public
VAPID_PRIVATE_KEY=changeme-vapid-private
