# .env.production — Production environment template for Voltana VPS deployment.
# Copy to /opt/voltana/.env and fill in every value before the first deploy.
# Generate secrets with: openssl rand -hex 32

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=voltana.example.com
APP_URL=https://voltana.example.com
APP_ENV=production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=9090

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=voltana
POSTGRES_USER=voltana_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── SMTP (Resend recommended; Mailgun also works) ─────────────────────────────
# Resend: https://resend.com — free tier 3000 emails/month
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=REPLACE_WITH_RESEND_API_KEY
SMTP_FROM=noreply@voltana.example.com

# ── Bale Bot (primary; preferred for Iranian VPS) ─────────────────────────────
# Obtain token from BotFather on Bale
BALE_BOT_TOKEN=REPLACE_WITH_BALE_BOT_TOKEN
BALE_BOT_USERNAME=your_bale_bot_username

# ── Telegram Bot (optional fallback; may be filtered on Iranian VPS) ──────────
# TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
# TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# ── Database Backups ──────────────────────────────────────────────────────────
BACKUP_DIR=/var/lib/voltana/backups
BACKUP_RETAIN_DAYS=7
POSTGRES_CONTAINER=voltana-postgres

# Optional S3-compatible backup upload (Backblaze B2 / AWS S3 / MinIO):
# AWS_S3_BACKUP_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL=https://s3.us-west-000.backblazeb2.com  # for Backblaze B2

# ── Health Check Alerts ───────────────────────────────────────────────────────
# Optional: Bale/Telegram bot to alert when /health check fails.
# ALERT_BOT_TOKEN=<same or different bot token>
# ALERT_CHAT_ID=<your personal chat ID or a group ID>
# ALERT_PLATFORM=bale   # or: telegram
# HEALTH_URL=https://voltana.example.com/health
